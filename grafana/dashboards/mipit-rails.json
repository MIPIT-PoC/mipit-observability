{
  "dashboard": {
    "id": null,
    "uid": "mipit-rails",
    "title": "MiPIT — Per-Rail Metrics",
    "tags": ["mipit", "rails"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Tasa de Éxito — PIX vs SPEI",
        "type": "bargauge",
        "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "targets": [
          {
            "expr": "sum(mipit_adapter_requests_total{status=\"SUCCESS\"}) by (rail) / sum(mipit_adapter_requests_total) by (rail) * 100",
            "legendFormat": "{{rail}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "max": 100,
            "min": 0,
            "unit": "percent",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "red" },
                { "value": 90, "color": "yellow" },
                { "value": 99, "color": "green" }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "orientation": "horizontal",
          "displayMode": "gradient",
          "showUnfilled": true,
          "minVizWidth": 0,
          "minVizHeight": 10
        }
      },
      {
        "id": 2,
        "title": "Errores por Riel",
        "type": "table",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "targets": [
          {
            "expr": "sum by (rail, error)(mipit_adapter_errors_total)",
            "legendFormat": "{{rail}} — {{error}}",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" },
                { "value": 5, "color": "yellow" },
                { "value": 20, "color": "red" }
              ]
            },
            "custom": {
              "align": "auto",
              "displayMode": "color-background-solid"
            }
          },
          "overrides": []
        },
        "options": {
          "showHeader": true,
          "sortBy": [{ "displayName": "Value", "desc": true }],
          "footer": { "show": false }
        },
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "rail": "Rail",
                "error": "Error Type",
                "Value": "Count"
              }
            }
          }
        ]
      },
      {
        "id": 3,
        "title": "Reintentos por Adaptador",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "targets": [
          {
            "expr": "sum(rate(mipit_adapter_retries_total[5m])) by (rail)",
            "legendFormat": "{{rail}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": { "mode": "palette-classic" },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 20,
              "drawStyle": "line",
              "gradientMode": "none",
              "showPoints": "auto"
            }
          },
          "overrides": []
        },
        "options": {
          "tooltip": { "mode": "multi", "sort": "desc" },
          "legend": {
            "displayMode": "list",
            "placement": "bottom",
            "showLegend": true
          }
        }
      },
      {
        "id": 4,
        "title": "Top Errores Más Frecuentes",
        "type": "table",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "targets": [
          {
            "expr": "topk(10, sum by (rail, error)(mipit_adapter_errors_total))",
            "legendFormat": "{{rail}} — {{error}}",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" },
                { "value": 10, "color": "yellow" },
                { "value": 50, "color": "red" }
              ]
            },
            "custom": {
              "align": "auto",
              "displayMode": "color-background-solid"
            }
          },
          "overrides": []
        },
        "options": {
          "showHeader": true,
          "sortBy": [{ "displayName": "Value", "desc": true }],
          "footer": { "show": false }
        },
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "rail": "Rail",
                "error": "Error Type",
                "Value": "Count"
              }
            }
          }
        ]
      }
    ]
  }
}
