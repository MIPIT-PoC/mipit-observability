{
  "dashboard": {
    "id": null,
    "uid": "mipit-latency",
    "title": "MiPIT — Latency by Stage",
    "tags": ["mipit", "latency"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Latencia por Etapa — Heatmap",
        "type": "heatmap",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "targets": [
          {
            "expr": "sum(rate(mipit_payment_latency_ms_bucket[5m])) by (le, stage)",
            "legendFormat": "{{stage}}",
            "refId": "A",
            "format": "heatmap"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "scheme", "schemeId": "Oranges" }
          },
          "overrides": []
        },
        "options": {
          "calculate": false,
          "yAxis": { "unit": "ms" },
          "tooltip": { "show": true, "yHistogram": true },
          "cellGap": 1,
          "color": { "mode": "scheme", "scheme": "Oranges", "steps": 64 }
        }
      },
      {
        "id": 2,
        "title": "Percentiles p50 / p95 / p99 por Etapa",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(mipit_payment_latency_ms_bucket[5m])) by (le, stage))",
            "legendFormat": "p50 — {{stage}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(mipit_payment_latency_ms_bucket[5m])) by (le, stage))",
            "legendFormat": "p95 — {{stage}}",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(mipit_payment_latency_ms_bucket[5m])) by (le, stage))",
            "legendFormat": "p99 — {{stage}}",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "color": { "mode": "palette-classic" },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "pointSize": 5,
              "showPoints": "auto",
              "drawStyle": "line",
              "gradientMode": "none",
              "spanNulls": false
            }
          },
          "overrides": []
        },
        "options": {
          "tooltip": { "mode": "multi", "sort": "desc" },
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "showLegend": true,
            "calcs": ["mean", "max"]
          }
        }
      },
      {
        "id": 3,
        "title": "Latencia Adaptador PIX (p95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(mipit_adapter_latency_ms_bucket{rail=\"PIX\"}[5m])) by (le))",
            "legendFormat": "PIX p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(mipit_adapter_latency_ms_bucket{rail=\"PIX\"}[5m])) by (le))",
            "legendFormat": "PIX p50",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "color": { "mode": "palette-classic" },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 15,
              "drawStyle": "line",
              "gradientMode": "none"
            }
          },
          "overrides": []
        },
        "options": {
          "tooltip": { "mode": "multi", "sort": "desc" },
          "legend": {
            "displayMode": "list",
            "placement": "bottom",
            "showLegend": true
          }
        }
      },
      {
        "id": 4,
        "title": "Latencia Adaptador SPEI (p95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(mipit_adapter_latency_ms_bucket{rail=\"SPEI\"}[5m])) by (le))",
            "legendFormat": "SPEI p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(mipit_adapter_latency_ms_bucket{rail=\"SPEI\"}[5m])) by (le))",
            "legendFormat": "SPEI p50",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "color": { "mode": "palette-classic" },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 15,
              "drawStyle": "line",
              "gradientMode": "none"
            }
          },
          "overrides": []
        },
        "options": {
          "tooltip": { "mode": "multi", "sort": "desc" },
          "legend": {
            "displayMode": "list",
            "placement": "bottom",
            "showLegend": true
          }
        }
      },
      {
        "id": 5,
        "title": "Routing Decision Latency (p95)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 24, "x": 0, "y": 24 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(mipit_payment_latency_ms_bucket{stage=\"route_decision\"}[5m])) by (le))",
            "legendFormat": "Routing p95",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": null, "color": "green" },
                { "value": 50, "color": "yellow" },
                { "value": 200, "color": "red" }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto"
        }
      }
    ]
  }
}
